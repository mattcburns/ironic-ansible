[Unit]
Description=Ironic Conductor Service (Instance: %i)
Documentation=https://docs.openstack.org/ironic/latest/
After=docker.service mariadb.service rabbitmq.service ironic-api.service
Requires=docker.service

[Service]
Type=simple
Restart=on-failure
RestartSec=10s

ExecStartPre=-{{ docker_bin }} stop ironic-conductor-%i
ExecStartPre=-{{ docker_bin }} rm ironic-conductor-%i
ExecStartPre=-{{ docker_bin }} pull {{ ironic_image_repo }}/ironic:{{ ironic_image_tag }}

ExecStart={{ docker_bin }} run --name ironic-conductor-%i \
    --rm \
    --network {{ docker_network_name }} \
    -v {{ ironic_etc_dir }}/ironic.conf:/etc/ironic/ironic.conf:ro,z \
    -v {{ ironic_etc_dir }}/htpasswd:/etc/ironic/htpasswd:ro,z \
    -v {{ ironic_var_log_dir }}:/var/log/ironic:z \
    -v {{ ironic_http_images_dir }}:/shared/html:z \
    -e IRONIC_CONDUCTOR_HOST=ironic-conductor-%i \
    {{ ironic_image_repo }}/ironic:{{ ironic_image_tag }} \
    ironic-conductor

ExecStop={{ docker_bin }} stop ironic-conductor-%i

TimeoutStartSec=120
TimeoutStopSec=60

[Install]
WantedBy=multi-user.target
