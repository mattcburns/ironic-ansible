## Enroll + provision workflow
```bash
# 1) Create node
{{ ironic_cli_wrapper_path }} node create \
  --driver redfish \
  --driver-info redfish_address=<redfish https endpoint> \
  --driver-info redfish_username=<bmc user> \
  --driver-info redfish_password=<bmc password> \
  --driver-info redfish_verify_ca=False

# 2) Move to manageable
{{ ironic_cli_wrapper_path }} node manage <node id>

# 3) Attach cleaning network data
{{ ironic_cli_wrapper_path }} node set --network-data network_data.json <node id>

# 4) Move to available (runs cleaning)
{{ ironic_cli_wrapper_path }} node provide <node id>

# 5) Set deploy image
{% if ubuntu_lts_image_enabled | bool %}
{{ ironic_cli_wrapper_path }} node set <node id> \
  --instance-info image_type=whole-disk \
  --instance-info image_disk_format=qcow2 \
  --instance-info image_source={{ ubuntu_lts_image_http_url }} \
  --instance-info image_os_hash_algo=sha256 \
  --instance-info image_os_hash_value=$(curl -fsSL {{ ubuntu_lts_image_checksum_http_url }})
{% else %}
{{ ironic_cli_wrapper_path }} node set <node id> \
  --instance-info image_type=whole-disk \
  --instance-info image_disk_format=<raw|qcow2> \
  --instance-info image_source=<url to os image> \
  --instance-info image_os_hash_algo=sha256 \
  --instance-info image_os_hash_value=<os image sha256sum>
{% endif %}

# 6) Deploy
{{ ironic_cli_wrapper_path }} node deploy <node id> --configdrive <config-drive.json, optional>
```
