# {{ ansible_managed }}
# =============================================================================
# Ironic Configuration — Standalone Deployment
# =============================================================================

[DEFAULT]
# Authentication
{% if keystone_enabled %}
auth_strategy = keystone
{% else %}
auth_strategy = {{ ironic_auth_strategy }}
http_basic_auth_user_file = /etc/ironic/htpasswd
{% endif %}

# Logging
debug = {{ 'true' if ironic_log_level == 'DEBUG' else 'false' }}
log_dir = /var/log/ironic

# Message transport (RabbitMQ)
transport_url = rabbit://{{ rabbitmq_user }}:{{ rabbitmq_password }}@{{ rabbitmq_container_name }}:5672/{{ rabbitmq_vhost }}

# Hardware types and interfaces
enabled_hardware_types = {{ ironic_enabled_hardware_types }}

enabled_boot_interfaces = {{ ironic_enabled_boot_interfaces }}
default_boot_interface = {{ ironic_default_boot_interface }}

enabled_deploy_interfaces = {{ ironic_enabled_deploy_interfaces }}
default_deploy_interface = {{ ironic_default_deploy_interface }}

enabled_network_interfaces = {{ ironic_enabled_network_interfaces }}
default_network_interface = {{ ironic_default_network_interface }}

enabled_inspect_interfaces = {{ ironic_enabled_inspect_interfaces }}
default_inspect_interface = {{ ironic_default_inspect_interface }}

enabled_management_interfaces = {{ ironic_enabled_management_interfaces }}
enabled_power_interfaces = {{ ironic_enabled_power_interfaces }}
enabled_raid_interfaces = {{ ironic_enabled_raid_interfaces }}
grub_config_path = {{ ironic_grub_config_path }}

[api]
host_ip = {{ ironic_api_bind_addr }}
port = {{ ironic_api_port }}
api_workers = {{ ironic_api_workers }}

[conductor]
automated_clean = {{ 'true' if ironic_automated_clean | bool else 'false' }}
inspect_wait_timeout = {{ ironic_inspect_timeout }}
{% if ironic_bootloader | default('') | trim %}
bootloader = {{ ironic_bootloader }}
{% endif %}
{% if ironic_bootloader_by_arch | default('') | trim %}
bootloader_by_arch = {{ ironic_bootloader_by_arch }}
{% endif %}
{% if ironic_file_url_allowed_paths | default('') | trim %}
file_url_allowed_paths = {{ ironic_file_url_allowed_paths }}
{% endif %}
deploy_kernel = http://{{ ironic_api_host }}:{{ ironic_http_port }}/ipa/{{ ipa_kernel_filename }}
deploy_ramdisk = http://{{ ironic_api_host }}:{{ ironic_http_port }}/ipa/{{ ipa_ramdisk_filename }}

[database]
connection = mysql+pymysql://{{ mariadb_user }}:{{ mariadb_password }}@{{ mariadb_container_name }}:3306/{{ mariadb_database }}?charset=utf8

[deploy]
http_url = http://{{ ironic_api_host }}:{{ ironic_http_port }}/
http_root = /shared/html
default_boot_option = local
[pxe]
kernel_append_params = {{ ironic_ipa_kernel_append_params }}{% if ironic_ipa_ssh_public_key | default('') | trim %} sshkey="{{ ironic_ipa_ssh_public_key | trim }}"{% endif %}

[dhcp]
dhcp_provider = none

[inspector]
hooks = $default_hooks
power_off = true
extra_kernel_params =

[redfish]
kernel_append_params = {{ ironic_ipa_kernel_append_params }}{% if ironic_ipa_ssh_public_key | default('') | trim %} sshkey="{{ ironic_ipa_ssh_public_key | trim }}"{% endif %}
use_swift = false

[service_catalog]
{% if keystone_enabled %}
auth_url = {{ keystone_auth_url }}
auth_type = password
project_name = {{ keystone_project_name }}
username = {{ keystone_username }}
password = {{ keystone_password }}
user_domain_name = {{ keystone_user_domain_name }}
project_domain_name = {{ keystone_project_domain_name }}
{% else %}
auth_type = http_basic
username = {{ ironic_admin_username }}
password = {{ ironic_admin_password }}
endpoint_override = http://{{ ironic_api_host }}:{{ ironic_api_port }}
{% endif %}

{% if keystone_enabled %}
[keystone_authtoken]
auth_url = {{ keystone_auth_url }}
auth_type = password
project_name = {{ keystone_project_name }}
username = {{ keystone_username }}
password = {{ keystone_password }}
user_domain_name = {{ keystone_user_domain_name }}
project_domain_name = {{ keystone_project_domain_name }}
{% endif %}
