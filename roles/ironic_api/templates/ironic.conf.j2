# =============================================================================
# Ironic Configuration File (Generated by Ansible)
# =============================================================================
# This file is automatically generated. Do not edit manually.
# Modify variables in group_vars/all.yml and re-run the playbook.
# =============================================================================

[DEFAULT]
# Deployment mode
deployment_mode = {{ ironic_deployment_mode }}

# Logging
log_config = {{ ironic_log_file }}
debug = false
verbose = {{ 'true' if ironic_log_level == 'DEBUG' else 'false' }}

# Authentication
{% if ironic_authentication_method == 'http_basic' %}
auth_strategy = http_basic
{% elif ironic_authentication_method == 'keystone' and keystone_enabled %}
auth_strategy = keystone
{% else %}
auth_strategy = http_basic
{% endif %}

# Host and port
host = {{ ironic_api_bind_addr }}
port = {{ ironic_api_port }}

# CORS
enable_cors = {{ 'true' if ironic_enable_cors else 'false' }}
enable_metadatasvc = false

# Hostname
{% if ironic_hostname is defined %}
host_ip = {{ ironic_hostname }}
{% else %}
host_ip = {{ ironic_api_host }}
{% endif %}

# Conductor group
conductor_group = {{ ironic_conductor_group }}

# Database connection
{% if keystone_enabled %}
# For multi-host deployments, database connection will be in [conductor]
{% else %}
database_connection = mysql+pymysql://{{ mariadb_user }}:{{ mariadb_password }}@localhost:{{ mariadb_port }}/{{ mariadb_database }}
{% endif %}

# Message queue (RabbitMQ)
message_queue_url = rabbit://{{ rabbitmq_user }}:{{ rabbitmq_password }}@localhost:{{ rabbitmq_amqp_port }}/{{ rabbitmq_vhost }}

# Interface registration
boot_interface = {{ ironic_boot_interface }}
deploy_interface = {{ ironic_deploy_interface }}
network_interface = {{ ironic_network_interface }}
{% if ironic_inspect_interface is defined %}
inspect_interface = {{ ironic_inspect_interface }}
{% endif %}

# Drivers
driver = {{ ironic_driver }}

# HTTP proxy for IPA (optional)
# http_proxy =
# https_proxy =
# no_proxy =

# Image properties for IPA
image_path = http://{{ ironic_api_host }}:{{ ironic_http_port }}
{% if ironic_enable_ssl %}
image_path_secure = https://{{ ironic_api_host }}:{{ ironic_http_port }}
{% endif %}

# Conductor configuration
[conductor]
# Number of workers (adjust based on system resources)
workers = {{ ironic_conductor_workers | default(4) }}

# Database connection for conductor
{% if not keystone_enabled %}
database_connection = mysql+pymysql://{{ mariadb_user }}:{{ mariadb_password }}@localhost:{{ mariadb_port }}/{{ mariadb_database }}
{% endif %}

# Message queue
message_queue_url = rabbit://{{ rabbitmq_user }}:{{ rabbitmq_password }}@localhost:{{ rabbitmq_amqp_port }}/{{ rabbitmq_vhost }}

# Inspector configuration (Built-in agent inspection)
[inspector]
# Inspector API settings
bind_host = {{ ironic_inspector_bind_host }}
port = {{ ironic_inspector_listen_port }}

# Inspector interface
inspect_interface = agent

# Database connection
{% if not keystone_enabled %}
database_connection = mysql+pymysql://{{ mariadb_user }}:{{ mariadb_password }}@localhost:{{ mariadb_port }}/{{ mariadb_database }}
{% endif %}

# Message queue
message_queue_url = rabbit://{{ rabbitmq_user }}:{{ rabbitmq_password }}@localhost:{{ rabbitmq_amqp_port }}/{{ rabbitmq_vhost }}

# Inspection timeout
inspect_timeout = {{ ironic_inspect_timeout }}

# HTTP Basic Auth configuration
[ironic.http_basic]
# Password file location (managed by Ansible)
password_file = {{ ironic_etc_dir }}/htpasswd

# Redfish driver configuration
[ironic.redfish]
# Enable virtual media support
enable_virtual_media = true

# Redfish protocol version
protocol = redfish.v1

# HTTP Boot configuration
[ironic.redfish.https]
# HTTP boot URL
http_boot_url = http://{{ ironic_api_host }}:{{ ironic_http_port }}/boot

# No-op network interface
[ironic.noop.network]
# No configuration needed for noop network

# Agent inspection configuration
[inspector.agent]
# Enable agent inspection
enable_agent_inspection = true

# Agent ramdisk image path
agent_ramdisk_path = http://{{ ironic_api_host }}:{{ ironic_http_port }}/ipa/ironic-python-agent.kernel

# Agent initrd path
agent_initrd_path = http://{{ ironic_api_host }}:{{ ironic_http_port }}/ipa/ironic-python-agent.ramdisk

{% if keystone_enabled %}
# Keystone configuration
[keystone.authtoken]
auth_url = {{ keystone_auth_url }}
project_name = {{ keystone_project_name }}
username = {{ keystone_username }}
password = {{ keystone_password }}
user_domain_name = {{ keystone_user_domain_name }}
project_domain_name = {{ keystone_project_domain_name }}
{% endif %}
